APP_ENV=local

# Local Postgres defaults. Used when DATABASE_URL is empty.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_agent
POSTGRES_USER=stock_agent
POSTGRES_PASSWORD=stock_agent

# Optional override for personal/team Supabase or another Postgres instance.
# Local Docker example:
# DATABASE_URL=postgresql://stock_agent:stock_agent@localhost:5432/stock_agent
# Supabase pooler example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

NEWS_API_KEY=
ECOS_API_KEY=
FRED_API_KEY=
DART_API_KEY=