APP_ENV=local

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_agent
POSTGRES_USER=stock_agent
POSTGRES_PASSWORD=stock_agent
DATABASE_URL=postgresql://stock_agent:stock_agent@localhost:5432/stock_agent

NEWS_API_KEY=
FRED_API_KEY=
DART_API_KEY=

EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stock-agent-local

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-4.5-flash
GLM_TIMEOUT_SECONDS=30

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct
OPENROUTER_TIMEOUT_SECONDS=30

COMPETITOR_MCP_FALLBACK_ENABLED=true
COMPETITOR_MCP_TIMEOUT_SECONDS=20
